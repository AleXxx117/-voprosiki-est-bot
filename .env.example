# Создай нового бота через @BotFather и вставь сюда новый токен.
BOT_TOKEN=1234567890:replace_with_new_token

# Твой цифровой Telegram ID. Несколько ID можно указать через запятую.
ADMIN_IDS=123456789

# Необязательно. Можно позже привязать канал командой /setchannel.
CHANNEL_ID=@your_channel_username

# Автопубликации по местному времени, через запятую.
AUTOPOST_ENABLED=false
AUTOPOST_TIMES=10:00,19:00
TIMEZONE=Europe/Kyiv

# Через сколько секунд бот показывает следующую подсказку или букву.
ROUND_STEP_SECONDS=20

# Путь к локальному файлу статистики.
DATA_FILE=./data/state.json
